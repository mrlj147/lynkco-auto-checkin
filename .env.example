# Lynk & Co 自动签到 - 环境变量配置
# 复制此文件为 .env 并填入你的值

# 登录态 Token（30 分钟过期，自动刷新，不用管）
LYNKCO_CENTER_TOKEN=bearer你的token

# 刷新 Token（每次签到自动续期，不会过期）
LYNKCO_REFRESH_TOKEN=bearer你的refreshToken

# Bark 推送 Key
LYNKCO_BARK_KEY=你的BarkKey

# Token 缓存路径（持久化到 volume，防止容器重建后丢失）
LYNKCO_TOKEN_CACHE_PATH=/data/token_cache.json

# 签到窗口（默认凌晨 1 点到 6 点随机签到）
# 改成下午 1 点到 6 点：LYNKCO_CHECKIN_START=13 / LYNKCO_CHECKIN_END=18
LYNKCO_CHECKIN_START=1
LYNKCO_CHECKIN_END=6